# === Database ===
DATABASE_URL=postgresql://memforge:memforge_dev@localhost:5432/memforge

# === Embeddings ===
# "local" = all-MiniLM-L6-v2 via @xenova/transformers (384 dims, no API key)
# "openai" = text-embedding-3-small (1536 dims, requires OPENAI_API_KEY)
# "azure" = text-embedding-3-large (3072 dims, requires AZURE_EMBEDDING_ENDPOINT + AZURE_OPENAI_KEY)
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=sk-...

# === Azure OpenAI (optional) ===
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=gpt-4.1
AZURE_EMBEDDING_ENDPOINT=
AZURE_CHAT_ENDPOINT=

# === Entity Extraction ===
# "claude-haiku" or "gpt-4o-mini"
EXTRACTION_MODEL=claude-haiku
ANTHROPIC_API_KEY=sk-ant-...
LLM_EXTRACTION_ENABLED=false

# === Server ===
MEMFORGE_PORT=3100

# === Background Jobs ===
DECAY_INTERVAL_HOURS=24
REFLECT_INTERVAL_HOURS=12

# === Recall Defaults ===
DEFAULT_TOKEN_BUDGET=4000

# === Dedup Thresholds ===
DEDUP_THRESHOLD=0.95
CONFLICT_THRESHOLD=0.80

# === Features ===
HYBRID_SEARCH_ENABLED=true
RERANKER_ENABLED=true
QUERY_DECOMPOSITION_ENABLED=true
AGENTIC_RECALL_ENABLED=false
