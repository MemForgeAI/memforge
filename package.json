{
  "name": "memforge",
  "version": "0.1.0",
  "description": "The open-source memory layer for AI agents — MCP server backed by PostgreSQL + pgvector + Apache AGE",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:integration": "vitest run src/mcp-integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "memory", "ai-memory", "long-term-memory", "ai-agents", "llm", "rag", "postgresql", "pgvector", "knowledge-graph", "semantic-search", "vector-database"],
  "author": "Surya Koritala",
  "homepage": "https://memforge.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/MemForgeAI/memforge.git"
  },
  "bugs": {
    "url": "https://github.com/MemForgeAI/memforge/issues"
  },
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "memforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "init.sql",
    "docker-compose.yml",
    "Dockerfile",
    "docker/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.0",
    "pg": "^8.13.0",
    "express": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
